# See https://help.github.com/articles/ignoring-files/

# --- Dependencies ---
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Optional package manager stores (uncomment if you use them)
# .pnpm-store/

# --- Build & output ---
.next/
out/
build/
dist/
storybook-static/

# --- Next.js / tooling caches ---
.turbo/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# --- Testing & coverage ---
coverage/
.nyc_output/
playwright-report/
test-results/
blob-report/
playwright/.cache/

# --- Environment & secrets ---
# Keep `.env.example` (or similar) committed; ignore real env files.
.env
.env.*
!.env.example
!.env*.example

# --- Vercel ---
.vercel

# --- Local / debug ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.DS_Store
Thumbs.db
Desktop.ini

# --- Certificates & keys (never commit) ---
*.pem
*.key
*.p12
*.pfx

# --- IDE & editors ---
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# VS Code — ignore user-specific; allow shared workspace settings if you add them
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# --- OS ---
.AppleDouble
.LSOverride
._*
